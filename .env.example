# Copie para .env e preencha. O .env NÃO é commitado (ver .gitignore).

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# MongoDB
MONGO_URI=mongodb://user:pass@host:27017
MONGO_DB=wynn_guild

# WynnCraft
WYNN_GUILD_PREFIX=
# Opcional: aumenta o limite de requisições. Deixe vazio se não tiver.
WYNN_API_KEY=
# Como enviar a chave: "bearer" (Authorization: Bearer <key>) ou "raw"
# (Authorization: <key>). Confirme no seu dashboard de desenvolvedor.
WYNN_API_KEY_SCHEME=bearer

# Healthcheck HTTP (Easypanel). Porta interna do container.
PORT=8080
